# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Local MongoDB (for development)
# MONGODB_URI=mongodb://localhost:27017/agromarket

# MongoDB Atlas (Production - update with your credentials)
# Format: mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agromarket?retryWrites=true&w=majority

# JWT Configuration (Change in production!)
JWT_SECRET=your_jwt_secret_key_change_in_production_12345678

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# CORS Configuration (Update with your frontend URL)
CORS_ORIGIN=http://localhost:8080

# Email Configuration (Optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password